{
  "permissions": {
    "allow": [
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(uv:*)",
      "Bash(pixi:*)",
      "Bash(python -m pipeline:*)",
      "Bash(python -m eval:*)",
      "Bash(python -m tests:*)",
      "Bash(python scripts/train_cnn1d.py:*)",
      "Bash(python scripts/train_lstm.py:*)",
      "Bash(python scripts/train_cnn_lstm.py:*)",
      "Bash(python scripts/train_tcn.py:*)",
      "Bash(python scripts/train_with_top_k.py:*)",
      "Bash(python scripts/sweep_top_k.py:*)",
      "Bash(python scripts/analyze_features.py:*)",
      "Bash(python scripts/ablate_modalities.py:*)",
      "Bash(python scripts/generate_plots.py:*)",
      "Bash(python scripts/compare_architectures.py:*)",
      "Bash(python scripts/compare_all.py:*)",
      "Bash(python scripts/run_overnight.py:*)",
      "Bash(mkdir -p runs/*)",
      "Bash(mkdir -p logs/*)",
      "Bash(cp runs/*)",
      "Bash(mv runs/*)",
      "Bash(nvidia-smi)",
      "Bash(nvidia-smi:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(uv pip install:*)",
      "Bash(pip install:*)",
      "Bash(rm:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./data/private/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-and-check.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-no-filtfilt.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-no-joint-in-streaming.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/verify-references.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/verify-labeled-data.sh"
          }
        ]
      }
    ]
  }
}
