# Raw recordings (too large for GitHub - keep in external storage)
dataset/
dataset_aligned/
dataset_clean/

# Generated artifacts (regenerable from /label and /train)
# Anchor to repo root with leading slash so we don't accidentally ignore
# src/data/ (the Python package) — gitignore patterns without leading slash
# match the directory at any depth.
# Ignore everything in /data/ except /data/labeled/. Git can't unignore
# children of an ignored directory directly, so we ignore /data/* and then
# whitelist labeled/. labeled parquets stay in git so training can run on
# another machine without copying dataset_aligned/ (~6 GB). 10 recordings
# × ~20 MB each = ~250 MB total. /label overwrites them in-place.
/data/*
!/data/labeled/
/runs/
/inspections/
/logs/
/diagrams/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.venv/
venv/
env/

# Test/cache
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
.coverage.*

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code runtime state (lock files, scheduled tasks)
.claude/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Windows "Copy of" duplicates created when files are duplicated in Explorer
*\(1\).md
*\(1\).sh
*\(1\).json
*\(1\).py
*\(1\).yaml
*\(1\).yml

# Large parquet/csv outputs
*.parquet
!runs/*/metrics*.json
# Allow only the authoritative labeled parquets. window_features.parquet
# and similar derived files are regenerated by /train in seconds and stay
# out of git.
!data/labeled/**/aligned_features.parquet

# Logs
*.log

# Visualization cache (regenerable from scripts/visualize_session.py)
cache/

# Local Claude settings overrides
.claude/settings.local.json
